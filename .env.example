# ==========================================
# Server Environment Variables
# ==========================================
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/taskflow?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here
NODE_ENV=development

# Set FRONTEND_URL only if frontend is hosted separately
# For Railway (single service), leave it unset — frontend is served from the same origin
# FRONTEND_URL=http://localhost:5173

# ==========================================
# Client Environment Variables (client/.env)
# Only needed for local development
# In production, the client is served from the same server
# ==========================================
# VITE_API_URL=http://localhost:5000/api
